# ---------------------------------------------------------------------------
# wealthfolio-connect-self-hosted — environment variable template
#
# Copy this file to `.env` and fill in real values. Every variable consumed
# by the server is listed below; the canonical loader is
# internal/infrastructure/config/config.go.
#
#   - Required variables MUST be set or the server refuses to start.
#   - Optional variables show their default in [brackets] after the name.
#   - An empty credential pair simply disables that integration at startup,
#     so feel free to leave unused exchanges blank.
# ---------------------------------------------------------------------------

# =============================================================================
# Required
# =============================================================================
DATABASE_URL=postgres://wealth:CHANGE_ME@localhost:5432/wealthfolio?sslmode=disable
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
CONNECT_AUTH_PUBLISHABLE_KEY=CHANGE_ME

# Comma-separated allow-list of email addresses authorised to log in
# through the synthetic Supabase OTP endpoints. The Wealthfolio frontend
# must be built with CONNECT_AUTH_URL pointing at this server. Access is
# gated by CONNECT_AUTH_PUBLISHABLE_KEY plus this allow-list; the
# deployment is expected to be reachable only over a trusted network
# (VPN, reverse proxy, IP allow-list, ...).
#
# The legacy single-value SELF_HOSTED_USER_EMAIL is still accepted as a
# fallback when ALLOWED_EMAILS is unset.
ALLOWED_EMAILS=me@example.com

# Optional fixed OTP code accepted by /auth/v1/verify in addition to any
# 6-digit numeric value. Useful when a non-numeric memorable code is
# preferred for manual login. Leave empty to require 6 digits only.
STATIC_OTP=

# =============================================================================
# HTTP server
# =============================================================================
SERVER_PORT=8080                       # [8080]
LOG_LEVEL=info                         # [info]   trace|debug|info|warn|error
CORS_ORIGINS=*                         # [*]      comma-separated origins

# =============================================================================
# Auth modes
# =============================================================================
STATIC_TOKEN_MODE=false                # [false]  true → skip Connect handshake
TOKEN_TTL_SECONDS=3600                 # [3600]

# =============================================================================
# Sync scheduler
# =============================================================================
SYNC_INTERVAL_MINUTES=60               # [60]

# =============================================================================
# Futu OpenD (TCP, run locally as sidecar / DaemonSet)
# =============================================================================
FUTU_HOST=127.0.0.1                    # [127.0.0.1]
FUTU_PORT=11111                        # [11111]
FUTU_TRADE_PASSWORD=                   # MD5 hash of your trade password (32-char hex string)
FUTU_CONNECTION_ID=wealthfolio-connect # [wealthfolio-connect]
FUTU_RSA_KEY_FILE=                     # path to RSA private key PEM (matches OpenD's RSA_PrivateKey)

# =============================================================================
# IBKR Gateway / TWS (run locally as sidecar)
# =============================================================================
IBKR_HOST=127.0.0.1                    # [127.0.0.1]
IBKR_PORT=4001                         # [4001] 4001 gw-live, 4002 gw-paper, 7496 tws-live, 7497 tws-paper
IBKR_CLIENT_ID=17                      # [17]   any positive integer unique per connection
IBKR_ACCOUNT_ID=                       # optional — filter positions when gateway has multiple

# =============================================================================
# OKX CEX  (api.okx.com /api/v5/account/...)
# =============================================================================
OKX_API_KEY=
OKX_API_SECRET=                        # legacy alias also accepted: OKX_SECRET
OKX_PASSPHRASE=

# =============================================================================
# OKX Web3 / DEX  (api.okx.com /api/v5/dex/...)
# Separate credentials issued under the OKX Web3 product.
# =============================================================================
OKX_WEB3_API_KEY=
OKX_WEB3_API_SECRET=                   # legacy alias also accepted: OKX_WEB3_SECRET
OKX_WEB3_PASSPHRASE=

# =============================================================================
# Binance Spot  (api.binance.com /api/v3/...)
# =============================================================================
BINANCE_API_KEY=
BINANCE_API_SECRET=                    # legacy alias also accepted: BINANCE_SECRET

# =============================================================================
# Bitget Spot  (api.bitget.com /api/v2/spot/...)
# =============================================================================
BITGET_API_KEY=
BITGET_API_SECRET=                     # legacy alias also accepted: BITGET_SECRET
BITGET_PASSPHRASE=

# =============================================================================
# Hyperliquid (read-only — /info endpoint is fully public)
# =============================================================================
HYPERLIQUID_WALLET=                    # 0x... EVM address

# =============================================================================
# DeFi wallets (consumed by the OKX Web3 integration)
# JSON list of {name, address, chains[]}. `chains` are OKX chainIndex strings.
# Example:
#   DEFI_WALLETS=[{"name":"main","address":"0xabc...","chains":["1","56","137"]}]
# =============================================================================
DEFI_WALLETS=[]
